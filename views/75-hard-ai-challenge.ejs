                <input type="checkbox" name="consent" class="mt-1 h-4 w-4 rounded border-border-subtle bg-page text-accent focus:ring-accent">
                <span>I agree to receive challenge emails and updates about the 75 Hard AI Challenge. <span class="text-red-400">*</span></span>
              </label>
              <p class="text-red-400 text-xs mt-1 hidden" data-error="consent"></p>
            </div>

            <p id="hard-ai-signup-success" class="hidden rounded-lg border border-green-400/30 bg-green-400/10 px-4 py-3 text-sm text-green-300"></p>
            <p id="hard-ai-signup-error" class="hidden rounded-lg border border-red-400/30 bg-red-400/10 px-4 py-3 text-sm text-red-300"></p>

            <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-accent px-8 py-4 text-white font-semibold transition-colors hover:bg-accent-hover" data-magnetic>
              Join the Challenge
            </button>
          </form>
          <p class="mt-6 text-sm text-text-muted tracking-[0.15em]">#75HardAI</p>
        </div>
