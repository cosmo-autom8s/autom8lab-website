            <h3 class="text-lg font-display font-semibold mt-3 mb-6">Specialty Clinic, Florida</h3>
            <div class="space-y-4 mb-6">
              <div>
                <div class="text-3xl font-display font-bold"><span data-count-from="55" data-count-to="70" data-count-suffix="%" data-count-prefix="">55</span><span class="text-text-muted mx-2">&rarr;</span><span class="text-accent">70%</span></div>
                <div class="text-xs text-text-muted font-body mt-1">Treatment completion</div>
              </div>
              <div class="flex gap-6 text-sm">
                <div><div class="text-text-primary font-semibold">&lt;2 hrs</div><div class="text-xs text-text-muted font-body">Lead response</div></div>
                <div><div class="text-text-primary font-semibold">&darr;12%</div><div class="text-xs text-text-muted font-body">Missed appts</div></div>
